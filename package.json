{
  "name": "ncic-vehicle-lookup",
  "version": "1.2.0",
  "description": "Synchronous NCIC vehicle code lookups (make, model, color, style) from NIEM 6.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/data"
  ],
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "ncic",
    "vehicle",
    "make",
    "dmv",
    "niem",
    "vin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sen4ik/ncic-vehicle-lookup.git"
  },
  "homepage": "https://github.com/sen4ik/ncic-vehicle-lookup#readme",
  "author": "sen4ik",
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "dts": true,
    "clean": true
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
